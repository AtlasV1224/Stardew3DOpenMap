{
    "$schema": "https://smapi.io/schemas/content-patcher.json",
    "Changes": [
        // ---------
        // Warp Removal
        // ---------

        // ---------
        // Custom warp adding
        // ---------
        {
            "Action": "EditMap",
            "Target": "Maps/Backwoods",
            "AddWarps": [
                "-1 33 {{ModId}}_BackwoodsWest 46 33",
                "-1 34 {{ModId}}_BackwoodsWest 46 34",
                "-1 35 {{ModId}}_BackwoodsWest 46 35",
            ]
        },

        // ---------
        // Custom Location Definitions 
        // (alphabetical name then clockwise direction)
        // ---------
        {
            "Action": "Load",
            "Target": "Maps/{{ModId}}_BackwoodsWest",
            "FromFile": "Assets/Maps/BackwoodsWest.tmx",
        },

        // ---------
        // Vanilla Location Edits 
        // (alphabetical name then clockwise direction)
        // ---------
        // FIXME: Move Vanilla warps to map border
        {
            "Action": "EditMap",
            "Target": "Maps/Backwoods",
            "FromFile": "Assets/Maps/BackwoodsExtensionRight.tmx",
            "ToArea": {
                "X": 50,
                "Y": 0,
                "Width": 4,
                "Height": 42
            }
        },
        {
            "Action": "EditMap",
            "Target": "Maps/Backwoods",
            "FromFile": "Assets/Maps/BackwoodsExtensionBottom.tmx",
            "ToArea": {
                "X": 0,
                "Y": 40,
                "Width": 50,
                "Height": 2
            }
        },
        {
            "Action": "EditMap",
            "Target": "Maps/Backwoods",
            "PatchMode": "Replace",
            "FromFile": "Assets/Maps/BackwoodsModification1.tmx",
            "ToArea": {
                "X": 0,
                "Y": 27,
                "Width": 17,
                "Height": 13
            }
        },

        // ---------
        // Custom Location Edits 
        // (alphabetical name then clockwise direction)
        // ---------
        // FIXME: warps
        {
            "Action": "EditData",
            "Target": "Data/Locations",
            "Entries": {
                "{{ModId}}_BackwoodsWest": {
                    "DisplayName": "BackwoodsWest",
                    "DefaultArrivalTile": "10, 18",
                    "CreateOnLoad": {
                        "MapPath": "Maps/{{ModId}}_BackwoodsWest"
                    }
                }
            }
        },
    ]
}


